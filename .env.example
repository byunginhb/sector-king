# =====================================================================
# sector-king 환경변수 템플릿
# 사용법: 이 파일을 .env.local로 복사 후 값을 채워 넣는다.
#   cp .env.example .env.local
# 운영 배포는 Vercel 대시보드 → Project → Settings → Environment Variables
# .env.local / .env.* 은 .gitignore에 의해 무시된다.
# =====================================================================

# ────────────────────────────────────────────────────────────────────
# Supabase — 클라이언트 노출 가능
# (NEXT_PUBLIC_ 접두사는 브라우저 번들에 포함되므로 절대 비밀키 넣지 말 것)
# ────────────────────────────────────────────────────────────────────

# Supabase 프로젝트 URL (대시보드 → Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key (대시보드 → Project Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 사이트 URL (OAuth redirect 계산용)
# 로컬 개발: http://localhost:3000
# 운영: https://sector-king.com  (실제 운영 도메인으로 교체)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 Measurement ID (https://analytics.google.com → 속성 → 데이터 스트림)
# 미설정 시 GA 스크립트 미로드 (개발 시 추적 안됨 — 의도)
NEXT_PUBLIC_GA_MEASUREMENT_ID=


# ────────────────────────────────────────────────────────────────────
# Supabase — 서버 전용 (절대 클라이언트 노출 금지)
# NEXT_PUBLIC_ 접두사가 없는 변수는 서버에서만 접근 가능하다.
# 코드에서는 lib/supabase/admin.ts 단일 진입점에서만 import 한다.
# ────────────────────────────────────────────────────────────────────

# Supabase service_role key (대시보드 → Project Settings → API → service_role secret)
# RLS 우회 권한이 있으므로 절대 git/클라이언트에 유출 금지
SUPABASE_SERVICE_ROLE=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Postgres 직접 연결 문자열 (Drizzle 마이그레이션 + cron 데이터 수집용)
# 대시보드 → Project Settings → Database → Connection string → URI 모드
# 비밀번호는 프로젝트 생성 시 설정한 DB password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres


# ────────────────────────────────────────────────────────────────────
# 관리자 (admin) 설정
# 이 이메일 목록과 매칭되는 사용자가 첫 로그인 시 자동으로 role=admin 부여
# 쉼표(,) 구분, 공백 없이
# ────────────────────────────────────────────────────────────────────

ADMIN_EMAILS=byunginhb@gmail.com


# ────────────────────────────────────────────────────────────────────
# (선택) GitHub Actions cron 데이터 수집용 — Phase B 전환 시 사용
# 위 DATABASE_URL을 GitHub repository secrets에 동일 이름으로 등록
# 코드 변경 없이 secret 값만 추가하면 됨
# ────────────────────────────────────────────────────────────────────

# DATABASE_URL은 위에서 정의됨 — Vercel + GitHub Actions 양쪽에 등록


# ────────────────────────────────────────────────────────────────────
# (선택) 이메일 발송 — Phase B1 일별 마켓 리포트 (M4)
# RESEND_API_KEY 가 미설정이면 UI 토글이 비활성화되고, 발송 시도는
# `email_log.status='skipped'` 로 기록된다. 도메인 인증(SPF/DKIM/DMARC)
# 후 키를 등록하면 즉시 활성화된다.
# ────────────────────────────────────────────────────────────────────

# Resend API key (https://resend.com → API Keys)
RESEND_API_KEY=

# 발신 주소 (기본: 'Sector King <noreply@sectorking.co.kr>')
RESEND_FROM_EMAIL=


# ────────────────────────────────────────────────────────────────────
# 마켓 리포트 외부 ingestion API
# POST /api/news/ingest 호출 시 헤더 `Authorization: Bearer <KEY>` 또는
# `X-API-Key: <KEY>` 로 인증한다. 미설정 시 endpoint 가 503 으로 비활성화.
# 입력 JSON 포맷: docs/news-format.json 참조 (zod 스키마와 1:1).
# 권장 키 생성: `openssl rand -hex 32`
# ────────────────────────────────────────────────────────────────────
NEWS_INGEST_API_KEY=


# ────────────────────────────────────────────────────────────────────
# 일별 마켓 리포트 메일 cron (Phase B1 — M5)
# GitHub Actions 가 매시 0분(UTC)에 POST /api/cron/daily-news-email 호출.
# 헤더 `Authorization: Bearer <CRON_SECRET>` 로 인증한다.
# 미설정 시 endpoint 503 반환. 권장 키 생성: `openssl rand -hex 32`
#
# 등록 위치:
#   - Vercel: Settings → Environment Variables (Production / Preview)
#   - GitHub: Settings → Secrets and variables → Actions
#     · CRON_SECRET (위와 동일한 값)
#     · CRON_TARGET_URL (예: https://sector-king.com)
# ────────────────────────────────────────────────────────────────────
CRON_SECRET=


# ────────────────────────────────────────────────────────────────────
# 경제 캘린더 FRED 자동수집 (14_econ_calendar — Phase B)
# GitHub Actions(`.github/workflows/update-economic-calendar.yml`) 가 평일
# KST 06:00 에 POST /api/cron/economic-calendar-sync 를 호출하면, 서버가
# 이 키로 FRED `releases/dates` 를 조회해 미국 지표 발표일정을 upsert 한다.
# 미설정 시 endpoint 가 500 반환(런타임에만 필요 — 빌드/타입은 키 없이 통과).
# 무료 발급(즉시, 120 req/min): https://fred.stlouisfed.org/docs/api/api_key.html
#
# 등록 위치:
#   - Vercel: Settings → Environment Variables (Production)
#   (Actions 는 CRON_SECRET/CRON_TARGET_URL 만 사용 — 엔드포인트가 FRED 호출)
# ────────────────────────────────────────────────────────────────────
FRED_API_KEY=

